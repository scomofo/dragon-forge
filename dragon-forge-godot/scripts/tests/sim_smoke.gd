	var completion_vfx: Dictionary = HardwareDungeonData.get_completion_vfx_profile("great_buffer")
	_assert(completion_vfx["burst_kind"] == "prism" and completion_vfx["screen_effect"] == "scanline_burst", "completed hardware dungeons expose a final relay flash VFX profile")
	dungeon_scene.free()
	var first_flight_profile := ActOneProgressionData.complete_first_flight(DragonProgression.create_profile("fire"))
	_assert(DragonProgression.has_key_item(first_flight_profile, "10mm_wrench") and DragonProgression.has_mission_flag(first_flight_profile, "first_flight_complete"), "first flight grants wrench and story flag")
	var recovery_profile := ActOneProgressionData.complete_kernel_recovery(first_flight_profile)
	_assert(DragonProgression.has_key_item(recovery_profile, "silken_data") and DragonProgression.has_mission_flag(recovery_profile, "magma_core_compiled"), "kernel recovery saves Weaver and compiles Magma-Core")
	var saddle_profile := ActOneProgressionData.craft_friction_saddle(recovery_profile)
	_assert(DragonProgression.has_key_item(saddle_profile, "friction_saddle"), "Felix and Weaver can craft Friction Saddle after Kernel Recovery")
	var chased_profile := ActOneProgressionData.complete_bounty_hunter_chase(saddle_profile)
	_assert(DragonProgression.has_mission_flag(chased_profile, "bounty_hunters_evaded") and DragonProgression.has_key_item(chased_profile, "hunter_latency_read"), "bounty hunter chase becomes a required playable breakout step")
	var act_one_ready := ActOneProgressionData.great_breakout_ready(saddle_profile)
	_assert(not act_one_ready["ready"] and act_one_ready["next_action"] == "bounty_hunter_chase", "friction saddle alone still requires the bounty hunter chase")
	act_one_ready = ActOneProgressionData.great_breakout_ready(chased_profile)
	_assert(act_one_ready["ready"] and act_one_ready["next_dungeon"] == "southern_partition_airlock", "evading hunters readies the Southern Partition Airlock breakout")
	var act_two_profile := ActTwoProgressionData.enter_tundra(saddle_profile)
	_assert(DragonProgression.has_mission_flag(act_two_profile, "act_two_started") and DragonProgression.has_key_item(act_two_profile, "silicon_shards"), "entering tundra starts Act II and grants first silicon shards")
	var purge_profile := ActTwoProgressionData.shelter_from_white_out(act_two_profile, true)
	_assert(DragonProgression.has_mission_flag(purge_profile, "white_out_purge_survived"), "physical relay shelter completes white-out onboarding")
	var unit_profile := ActTwoProgressionData.meet_unit_01(purge_profile)
	_assert(DragonProgression.has_mission_flag(unit_profile, "unit_01_met") and DragonProgression.has_key_item(unit_profile, "unit_01_save_link"), "Unit 01 becomes mobile shop and save link")
	var locked_lens_profile := ActTwoProgressionData.complete_great_buffer(unit_profile)
	_assert(not DragonProgression.has_key_item(locked_lens_profile, "optical_lens"), "great buffer stays locked until the mirror admin projection is repelled")
	var ambush_profile := DragonProgression.set_mission_flag(unit_profile, "mirror_admin_tundra_repelled")
	ambush_profile = DragonProgression.grant_key_item(ambush_profile, "parity_trace")
	var great_buffer_tile := WorldData.get_tile_at(WorldData.create_world_state(), Vector2i(22, 6))
	_assert(great_buffer_tile["dungeon_id"] == "great_buffer", "great buffer vault is mapped as a side-scrolling dungeon")
	var great_buffer_roster := HardwareDungeonData.get_dungeon_enemy_roster_profile("great_buffer")
	_assert(great_buffer_roster["presentation"] == "hardware_process_roster" and great_buffer_roster["has_platform_drone"] and great_buffer_roster["has_static_stalker"], "Great Buffer enemy roster exposes Type-S drones and Bit-Rot Stalkers")
	var admin_gate_tile := WorldData.get_tile_at(WorldData.create_world_state(), Vector2i(23, 5))
	_assert(admin_gate_tile["dungeon_id"] == "mirror_admin_gate" and admin_gate_tile["artifact"] == "admin_shard", "Mirror Admin Gate is mapped as the Tundra exit dungeon")
	var admin_gate_roster := HardwareDungeonData.get_dungeon_enemy_roster_profile("mirror_admin_gate")
	_assert(admin_gate_roster["enemy_count"] == 1 and admin_gate_roster["has_platform_drone"] and not admin_gate_roster["has_static_stalker"], "Mirror Admin Gate focuses its enemy roster on platform drones before the Sentinel")
	var lens_profile := ActTwoProgressionData.complete_great_buffer(ambush_profile)
	_assert(DragonProgression.has_key_item(lens_profile, "optical_lens") and DragonProgression.has_mission_flag(lens_profile, "dungeon_great_buffer_complete"), "great buffer completion retrieves optical lens")
	var gate_reward_profile := HardwareDungeonData.apply_dungeon_completion_rewards("mirror_admin_gate", open_admin_gate_profile)
	_assert(DragonProgression.has_mission_flag(gate_reward_profile, "mirror_admin_sentinel_defeated") and DragonProgression.has_key_item(gate_reward_profile, "admin_shard") and DragonProgression.has_mission_flag(gate_reward_profile, "captains_log_mirror_admin_gate"), "Mirror Admin Gate completion saves the Sentinel defeat, reward, and Captain's Log flag")
	var captains_log_ui: Dictionary = HardwareDungeonData.get_captains_log_ui_profile(gate_reward_profile)
	_assert(captains_log_ui["presentation"] == "nes_log_index" and captains_log_ui["completion_label"] == "1/5 fragments", "Captain's Log UI profile exposes NES index presentation and completion count")
	_assert(captains_log_ui["chrome_style"]["panel_kind"] == "captains_log_archive" and captains_log_ui["chrome_style"]["scanline_alpha"] > 0.0, "Captain's Log UI profile carries archive chrome and scanline style tokens")
	var admin_log_entry := _captains_log_entry_for(captains_log_ui["entries"], "mirror_admin_gate")
	_assert(admin_log_entry["unlocked"] and admin_log_entry["state_label"] == "READABLE" and str(admin_log_entry["summary"]).contains("physical shielded ports"), "Captain's Log UI profile unlocks dungeon fragments from save flags")
	var locked_logic_entry := _captains_log_entry_for(captains_log_ui["entries"], "logic_core")
	_assert(not locked_logic_entry["unlocked"] and locked_logic_entry["state_label"] == "LOCKED" and str(locked_logic_entry["summary"]).contains("Complete"), "Captain's Log UI profile shows locked silhouettes for unfinished dungeons")
	var admin_story_beat := HardwareDungeonData.get_dungeon_completion_story_beat("mirror_admin_gate")
	_assert(admin_story_beat["presentation"] == "nes_story_card" and admin_story_beat["headline"] == "Admin Gate Sealed" and admin_story_beat["captains_log_flag"] == "captains_log_mirror_admin_gate", "Mirror Admin Gate completion has an authored story card and Captain's Log reveal")
	_assert(str(admin_story_beat["next_route"]).contains("Mainframe Spine") and str(admin_story_beat["admin_reveal"]).contains("hardware"), "Mirror Admin Gate story beat points the player toward the next route and clarifies the Admin weakness")
	var tuner_profile := ActTwoProgressionData.install_frequency_tuner(lens_profile)
	_assert(DragonProgression.has_key_item(tuner_profile, "frequency_tuner"), "Unit 01 can install frequency tuner after memory/log setup")
	var prism_profile := ActTwoProgressionData.mutate_prism_stalk(tuner_profile)
	_assert(DragonProgression.has_key_item(prism_profile, "prism_stalk_form") and DragonProgression.has_mission_flag(prism_profile, "prism_stalk_mutated"), "tundra data-light can mutate Prism-Stalk")
	var grip_profile := ActTwoProgressionData.install_insulated_grip(prism_profile)
	_assert(DragonProgression.has_key_item(grip_profile, "insulated_grip"), "Unit 01 can insulate the wrench for live data-bolts")
	var ascent_profile := ActTwoProgressionData.begin_spine_ascent(grip_profile)
	_assert(DragonProgression.has_mission_flag(ascent_profile, "mainframe_spine_ascent_started"), "mainframe spine ascent can begin after Prism-Stalk and insulated grip")
	var logic_profile := ActTwoProgressionData.complete_logic_core(ascent_profile)
	_assert(DragonProgression.has_key_item(logic_profile, "external_vents_unlocked") and DragonProgression.has_mission_flag(logic_profile, "dungeon_logic_core_complete"), "logic core unlocks external vents")
	var sentinel_profile := ActTwoProgressionData.bypass_root_sentinel(logic_profile)
	_assert(DragonProgression.has_key_item(sentinel_profile, "floppy_disk_backup") and DragonProgression.has_mission_flag(sentinel_profile, "root_sentinel_bypassed"), "root sentinel rewards floppy disk backup")
	var crown_profile := ActTwoProgressionData.complete_restoration_choice(sentinel_profile, RestorationData.CHOICE_PATCH)
	_assert(DragonProgression.has_mission_flag(crown_profile, "restoration_choice_patch") and DragonProgression.has_key_item(crown_profile, "read_only_free_roam"), "patch ending enters read-only free roam")
	_assert(crown_profile["ending_presentation"]["title"] == "The Patch" and crown_profile["credits_run"]["flight_mode"] == "ZERO_G_ROOT_AUTHORITY", "restoration choice stores ending presentation and credits run")

	print("Dragon Forge Godot sim smoke passed.")
	quit(0)

func _assert(condition: bool, message: String) -> void:
	if not condition:
		push_error("Smoke test failed: %s" % message)
		quit(1)

func _assert_lore_canon() -> void:
	_assert(LoreCanon.PLAYER["name"] == "Skye", "lore canon names Skye")
	_assert(str(LoreCanon.WORLD["astraeus"]).contains("Astraeus"), "lore canon exposes Astraeus")
	_assert(str(LoreCanon.WORLD["mirror_admin"]).contains("Mirror Admin"), "lore canon exposes Mirror Admin")
	_assert(str(LoreCanon.WORLD["great_reset"]).contains("Great Reset"), "lore canon exposes Great Reset")
	_assert(str(LoreCanon.DRAGON_PROTOCOL["summary"]).contains("protocols"), "lore canon frames dragons as protocols")
	_assert(LoreCanon.captain_log_fragments().size() >= 5, "lore canon exposes captain log fragments")

func _assert_story_world_lore(world: Dictionary) -> void:
	var boot_text := " ".join(StoryData.opening_boot_lines())
	_assert(boot_text.contains("SKYE"), "story opening names Skye")
	_assert(boot_text.contains("ASTRAEUS"), "story opening names Astraeus")
	_assert(boot_text.contains("MIRROR ADMIN"), "story opening names Mirror Admin")
	var felix_text := " ".join(StoryData.felix_first_contact_lines())
	_assert(felix_text.contains("Skye") and felix_text.contains("Astraeus"), "Felix first contact carries Skye and Astraeus")
	var forge_tile := WorldData.get_tile_at(world, Vector2i(13, 10))
	_assert(str(forge_tile.get("lore_signal", "")).contains("Astraeus"), "world lore signal exposes Astraeus at Felix lab")
	_assert(str(forge_tile.get("skye_objective", "")).contains("Skye"), "world lore objective frames Skye's route")

func _assert_opening_sequence_overlay() -> void:
	var opening := StoryData.opening_sequence_profile()
	_assert(opening["presentation"] == "tense_boot_first_contact", "opening sequence has a tense first-contact presentation profile")
	_assert(str(opening["stakes"]).contains("Great Reset") and str(opening["first_objective"]).contains("Root Dragon"), "opening sequence carries Great Reset stakes and first objective")
	var overlay := OpeningSequenceOverlay.new()
	var fresh_profile := DragonProgression.create_profile("fire")
	_assert(overlay.should_show_for_profile(fresh_profile), "opening overlay shows before the opening flag is saved")
	var seen_profile := DragonProgression.set_mission_flag(fresh_profile, "opening_sequence_seen")
	_assert(not overlay.should_show_for_profile(seen_profile), "opening overlay stays hidden once the opening flag is saved")
	var overlay_profile := overlay.get_sequence_profile_for_test()
	_assert(overlay_profile["id"] == "opening_sequence_seen" and overlay_profile["boot_lines"].size() >= 6 and overlay_profile["felix_lines"].size() >= 4, "opening overlay consumes boot and Felix first-contact lines")
	var opening_audio := overlay.get_audio_profile_for_test("warning")
	_assert(opening_audio["presentation"] == "nes_audio_scene_cue" and opening_audio["music"]["id"] == "opening_sequence" and opening_audio["music"]["mood"] == "tense", "opening overlay exposes tense NES-style music profile")
	_assert(opening_audio["sfx"]["id"] == "opening_warning_pulse" and opening_audio["sfx"]["dual_tone"], "opening overlay exposes warning SFX profile")
	var map_music := SfxData.get_music_profile("world_wandering")
	var battle_music := SfxData.get_music_profile("battle_tension")
	_assert(map_music["nes_style"] and map_music["mood"] == "uneasy_wonder" and battle_music["tempo_bpm"] > map_music["tempo_bpm"], "music schema separates wandering and tense battle loops")
	overlay.free()

func _assert_audio_director() -> void:
	var director := AudioDirectorService.new()
	var opening_cue: Dictionary = director.play_opening_sequence_cue("warning")
	_assert(opening_cue["music"]["id"] == "opening_sequence" and opening_cue["sfx"]["id"] == "opening_warning_pulse", "audio director routes opening scene cue to music and SFX profiles")
	var battle_music: Dictionary = director.play_music_context("battle_tension")
	_assert(battle_music["runtime_ready"] and battle_music["id"] == "battle_tension" and battle_music["intensity"] >= 0.9, "audio director can switch to battle tension runtime music")
	_assert(battle_music["synth_plan"]["presentation"] == "procedural_nes_music_plan" and battle_music["synth_plan"]["channels"]["pulse_1"].size() >= 4, "audio director attaches procedural NES music synth steps")
	director.play_music_context("world_wandering")
	var state: Dictionary = director.get_audio_state_for_test()
	_assert(state["current_music"]["id"] == "world_wandering" and state["last_sfx"]["id"] == "opening_warning_pulse" and state["cue_count"] >= 5, "audio director tracks current map music, last SFX, and cue history")
	_assert(state["last_music_synth_plan"]["channels"]["triangle"].size() >= 4 and state["last_sfx_synth_plan"]["presentation"] == "procedural_nes_sfx_plan", "audio director tracks music and SFX synth plans")
	_assert(state["playback_mode"] == "procedural_nes_synth_router", "audio director declares procedural synth routing as the current playback mode")
	_assert(SfxData.note_to_frequency("A4") == 440.0 and SfxData.note_to_frequency("A3") < 230.0, "SFX data can convert note names into synth frequencies")
	director.free()

func _has_command(commands: Array, id: String) -> bool:
	for command in commands:
		if command["id"] == id:
			return true
	return false

func _has_boundary_kind(boundaries: Array, boundary_kind: String) -> bool:
	for boundary in boundaries:
		if boundary.get("boundary_kind", "") == boundary_kind:
			return true
	return false

func _has_pressure_kind(pressures: Array, pressure_kind: String) -> bool:
	for pressure in pressures:
		if pressure.get("pressure_kind", "") == pressure_kind:
			return true
	return false

func _has_contour_kind(contours: Array, contour_kind: String) -> bool:
	for contour in contours:
		if contour.get("contour_kind", "") == contour_kind:
			return true
	return false

func _has_transition_layer(steps: Array, layer: String) -> bool:
	for step in steps:
		if step.get("layer", "") == layer:
			return true
	return false

func _anvil_entry_for(entries: Array, relic_id: String) -> Dictionary:
	for entry in entries:
		if str(entry.get("id", "")) == relic_id:
			return entry
	return {}

func _captains_log_entry_for(entries: Array, fragment_id: String) -> Dictionary:
	for entry in entries:
		if str(entry.get("id", "")) == fragment_id:
			return entry
	return {}
