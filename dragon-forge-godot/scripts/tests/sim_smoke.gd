extends SceneTree

const WorldData := preload("res://scripts/sim/world_data.gd")
const TacticalBattle := preload("res://scripts/sim/tactical_battle.gd")
const DragonProgression := preload("res://scripts/sim/dragon_progression.gd")
const MissionData := preload("res://scripts/sim/mission_data.gd")
const SideQuestData := preload("res://scripts/sim/sidequest_data.gd")
const VisualSystemData := preload("res://scripts/sim/visual_system_data.gd")
const ServiceTicketData := preload("res://scripts/sim/service_ticket_data.gd")
const SystemTicket := preload("res://scripts/sim/system_ticket.gd")
const Relic := preload("res://scripts/sim/relic.gd")
const QuestManager := preload("res://scripts/sim/quest_manager.gd")
const Inventory := preload("res://scripts/sim/inventory.gd")
const FlightTuningData := preload("res://scripts/sim/flight_tuning_data.gd")
const MirrorAdminLogic := preload("res://scripts/sim/mirror_admin_logic.gd")
const TransitionEffectData := preload("res://scripts/sim/transition_effect_data.gd")
const VictoryStateData := preload("res://scripts/sim/victory_state_data.gd")
const ActOneFinaleData := preload("res://scripts/sim/act_one_finale_data.gd")
const ActTwoTundraData := preload("res://scripts/sim/act_two_tundra_data.gd")
const MainframeSpineData := preload("res://scripts/sim/mainframe_spine_data.gd")
const RestorationData := preload("res://scripts/sim/restoration_data.gd")
const DragonVaultData := preload("res://scripts/sim/dragon_vault_data.gd")
const HardwareDungeonData := preload("res://scripts/sim/hardware_dungeon_data.gd")
const WeaverData := preload("res://scripts/sim/weaver_data.gd")
const BattleVfxData := preload("res://scripts/sim/battle_vfx_data.gd")
const SfxData := preload("res://scripts/sim/sfx_data.gd")
const AudioDirectorService := preload("res://scripts/sim/audio_director.gd")
const LoreCanon := preload("res://scripts/sim/lore_canon.gd")
const StoryData := preload("res://scripts/sim/story_data.gd")
const ProceduralVfxOverlay := preload("res://scripts/vfx/procedural_vfx_overlay.gd")
const BattleBackdrop := preload("res://scripts/battle/battle_backdrop.gd")
const BattleSceneScript := preload("res://scripts/battle/battle_scene.gd")
const ThreadfallOverlay := preload("res://scripts/world/threadfall_overlay.gd")
const WorldMapView := preload("res://scripts/world/world_map_view.gd")
const WorldScene := preload("res://scripts/world/world_scene.gd")
const OpeningSequenceOverlay := preload("res://scripts/world/opening_sequence_overlay.gd")
const HardwareDungeonScene := preload("res://scenes/dungeon/hardware_dungeon_scene.tscn")
const ActOneProgressionData := preload("res://scripts/sim/act_one_progression_data.gd")
const ActTwoProgressionData := preload("res://scripts/sim/act_two_progression_data.gd")
const CreditsRunDisplay := preload("res://scripts/world/credits_run_display.gd")

func _init() -> void:
	_assert_lore_canon()
	var world := WorldData.create_world_state()
	_assert_story_world_lore(world)
	_assert_opening_sequence_overlay()
	_assert_audio_director()
	_assert(WorldData.get_current_tile(world)["id"] == "new_landing", "starts in New Landing")
	world = WorldData.move_player(world, "east")
	_assert(WorldData.get_current_tile(world)["id"] == "testing_fields", "moves one overworld tile east into testing fields")
	world = WorldData.move_player(world, "east")
	_assert(WorldData.get_tile_danger(WorldData.get_current_tile(world)) > 0.0, "walkable terrain contributes overworld danger pressure")
	_assert(WorldData.get_wild_encounter(WorldData.get_current_tile(world)) != null, "field terrain can produce a wild encounter")
	world = WorldData.move_player_to(world, Vector2i(13, 10))
	_assert(WorldData.get_current_tile(world)["id"] == "forge_lab", "click travel moves to Felix lab")
	world = WorldData.move_player_to(world, Vector2i(17, 10))
	_assert(WorldData.get_current_tile(world)["id"] == "firewall_gate", "click travel moves to firewall gate")
	_assert(WorldData.get_world_encounter(world)["enemy_id"] == "firewall_sentinel", "gate has sentinel encounter")
	world = WorldData.move_player_to(world, Vector2i(15, 8))
	_assert(WorldData.get_current_tile(world)["id"] == "checksum_ring", "overworld has a visible battle arena")
	_assert(WorldData.get_current_tile(world)["arena"], "battle arena tile is marked as an arena")
	_assert(WorldData.get_current_tile(world)["arena_rule"] == "checksum_flux", "arena carries a distinct battle rule")
	_assert(WorldData.get_current_tile(world)["arena_reward"]["technique_id"] == "cinderComet", "arena advertises a first-clear technique reward")
	_assert(WorldData.get_world_encounter(world)["enemy_id"] == "corrupt_drake", "arena has its own enemy encounter")
	world = WorldData.move_player_to(world, Vector2i(21, 9))
	_assert(WorldData.get_current_tile(world)["id"] == "overgrown_buffer", "click travel moves into southern partition jungle")
	world = WorldData.move_player_to(world, Vector2i(27, 8))
	_assert(WorldData.get_current_tile(world)["id"] == "vault_first_rack", "click travel moves into vault of the first rack")
	_assert(WorldData.get_world_encounter(world)["enemy_id"] == "scrap_wraith", "vault has scrap-wraith encounter")
	world = WorldData.move_player_to(world, Vector2i(29, 9))
	_assert(WorldData.get_current_tile(world)["id"] == "cpu_heatsink", "moves into CPU heat sink mission tile")
	_assert(WorldData.get_current_tile(world)["mission"] == "mission_05", "CPU heat sink hosts heat sync mission")

	var relay_world := WorldData.create_world_state()
	relay_world = WorldData.move_player_to(relay_world, Vector2i(5, 15))
	_assert(WorldData.get_current_tile(relay_world)["id"] == "mint_menagerie", "click travel moves to walkable target tile")
	relay_world = WorldData.move_player_to(relay_world, Vector2i(0, 0))
	_assert(WorldData.get_current_tile(relay_world)["id"] == "mint_menagerie", "click travel ignores blocked wall target")
	relay_world = WorldData.create_world_state()
	relay_world = WorldData.move_player_to(relay_world, Vector2i(11, 13))
	_assert(WorldData.get_current_tile(relay_world)["id"] == "great_salt_flats", "salt flats are reachable from testing fields")
	relay_world = WorldData.move_player_to(relay_world, Vector2i(31, 15))
	_assert(WorldData.get_current_tile(relay_world)["id"] == "lunar_sector", "lunar sector is reachable from relay route")

	var battle := TacticalBattle.create_battle("fire")
	_assert(battle["player_hp"] == 110, "magma dragon hp matches web sim")
	_assert(battle["enemy_stagger"] == 0, "battle starts with an empty enemy stagger meter")
	battle = TacticalBattle.take_action(battle, "quickClaw", 0.0)
	_assert(battle["enemy_hp"] < battle["enemy_max_hp"], "quick claw damages enemy")
	_assert(battle["enemy_stagger"] > 0, "attacks build enemy stagger")
	_assert(battle["player_hp"] < battle["player_max_hp"], "enemy intent resolves damage")
	_assert(battle["log"].has("Counter read: the strike catches the wind-up."), "strike commands counter attack wind-ups")
	_assert(battle["turn"] == 2, "battle advances turn")
	var guard_battle := TacticalBattle.create_battle("fire")
	guard_battle = TacticalBattle.take_action(guard_battle, "guard", 0.0)
	_assert(guard_battle["focus"] == 3, "perfect guard against attack grants extra focus")
	_assert(guard_battle["enemy_stagger"] > 0, "perfect guard shakes enemy stance")

	var profile := DragonProgression.create_profile("fire")
	_assert(DragonProgression.get_dragon_level(profile) == 1, "dragon progression starts at level 1")
	profile = DragonProgression.award_dragon_xp(profile, DragonProgression.xp_to_next_level(1))
	_assert(DragonProgression.get_dragon_level(profile) == 2, "dragon xp can level up the active guardian")
	_assert(profile["known_techniques"].has("blazingFang"), "fire profile starts with a learned technique")
	_assert(DragonProgression.get_active_techniques(profile).has("blazingFang"), "fire profile starts with blazing fang equipped")
	var anvil_profile := DragonProgression.grant_key_item(DragonProgression.create_profile("fire"), "10mm_wrench")
	anvil_profile = DragonProgression.grant_key_item(anvil_profile, "optical_lens")
	var anvil_relics: Array = DragonProgression.get_available_anvil_relics(anvil_profile)
	_assert(anvil_relics.size() >= 2 and anvil_relics[0]["id"] == "10mm_wrench", "anvil relic catalog exposes owned analog relics as equip options")
	anvil_profile = DragonProgression.toggle_anvil_relic(anvil_profile, "10mm_wrench")
	anvil_profile = DragonProgression.toggle_anvil_relic(anvil_profile, "optical_lens")
	_assert(DragonProgression.get_equipped_anvil_relics(anvil_profile).size() == 2 and DragonProgression.get_carried_anvil_gear_labels(anvil_profile).has("10mm Wrench"), "anvil relic equip state persists carried map gear labels")
	var anvil_ui: Dictionary = DragonProgression.get_anvil_relic_ui_profile(anvil_profile)
	_assert(anvil_ui["title"] == "ANVIL RELIC LOADOUT" and anvil_ui["slots_used_label"] == "2/2" and anvil_ui["slot_pressure"] == 1.0, "anvil relic UI profile exposes slot pressure and loadout title")
	_assert(anvil_ui["carried_gear"].has("10mm Wrench") and anvil_ui["carried_gear"].has("Refractive Plate"), "anvil relic UI profile exposes carried gear labels for map and dungeons")
	_assert(anvil_ui["slot_rows"].size() == 2 and anvil_ui["slot_rows"][0]["label"] == "10mm Wrench" and anvil_ui["slot_rows"][1]["gear_label"] == "Refractive Plate", "anvil relic UI profile exposes explicit utility-belt slot rows")
	_assert(anvil_ui["slot_rows"][1]["socket_icon"] == "O" and str(anvil_ui["slot_rows"][1]["effect_label"]).contains("Hidden nodes"), "anvil socket rows expose relic icons and dungeon role text")
	var optical_anvil_entry := _anvil_entry_for(anvil_ui["entries"], "optical_lens")
	_assert(optical_anvil_entry["icon"] == "O" and str(optical_anvil_entry["loadout_summary"]).contains("Stalker avoidance") and str(optical_anvil_entry["loadout_summary"]).contains("data beams"), "anvil relic entries expose overworld and dungeon loadout summaries")
	_assert(anvil_ui["chrome_style"]["panel_kind"] == "anvil_socket_rack" and anvil_ui["chrome_style"]["border_color"] == Color("#ffd166"), "anvil relic UI profile carries cartridge-chrome style tokens")
	_assert(str(anvil_ui["footer_prompt"]).contains("SPACE toggles"), "anvil relic UI profile includes control prompt copy for the real equip surface")
	var anvil_belt: Dictionary = DragonProgression.get_anvil_utility_belt_profile(anvil_profile)
	_assert(anvil_belt["presentation"] == "anvil_to_dungeon_utility_belt" and anvil_belt["equipped_tools"].has("10mm_wrench") and anvil_belt["equipped_tools"].has("optical_lens"), "Anvil sockets export the real utility belt used by hardware dungeon entry")
	var buffer_loadout := HardwareDungeonData.get_dungeon_loadout_profile("great_buffer", anvil_belt)
	_assert(buffer_loadout["presentation"] == "dungeon_entry_loadout_check" and buffer_loadout["ready"] and buffer_loadout["readiness_label"] == "CACHE VAULT KIT", "hardware dungeon data exposes a ready loadout check for carried Anvil tools")
	var swap_anvil_profile := DragonProgression.grant_key_item(anvil_profile, "friction_saddle")
	var swap_anvil_ui: Dictionary = DragonProgression.get_anvil_relic_ui_profile(swap_anvil_profile)
	var friction_entry := _anvil_entry_for(swap_anvil_ui["entries"], "friction_saddle")
	_assert(friction_entry["state_label"] == "SWAP" and str(friction_entry["disabled_reason"]).contains("Swapping replaces"), "full anvil belt exposes swap-in state for extra relics")
	anvil_profile = DragonProgression.toggle_anvil_relic(anvil_profile, "10mm_wrench")
	_assert(not DragonProgression.is_anvil_relic_equipped(anvil_profile, "10mm_wrench"), "anvil relic UI can unequip a carried relic")
	var expanded_anvil_profile := DragonProgression.grant_key_item(anvil_profile, "unit_01_save_link")
	var expanded_anvil_ui: Dictionary = DragonProgression.get_anvil_relic_ui_profile(expanded_anvil_profile)
	_assert(expanded_anvil_ui["slot_count"] == 3 and expanded_anvil_ui["upgrade_hint"] == "Unit 01 save link installed.", "anvil relic UI profile reflects Unit 01 third-slot upgrade")
	var sidebar_scene := WorldScene.new()
	sidebar_scene.set_profile(expanded_anvil_profile)
	var sidebar_profile: Dictionary = sidebar_scene.get_sidebar_console_profile()
	_assert(sidebar_profile["uses_framed_cards"] and sidebar_profile["presentation"] == "playable_1991_equipment_log_screen", "world sidebar exposes framed equipment/log screen presentation")
	_assert(sidebar_profile["anvil_socket_count"] == 3 and sidebar_profile["log_card_count"] == 5, "world sidebar console profile includes anvil sockets and Captain's Log cards")
	_assert(sidebar_profile["anvil_chrome"]["panel_kind"] == "anvil_socket_rack" and sidebar_profile["log_chrome"]["panel_kind"] == "captains_log_archive", "world sidebar console profile exposes style chrome for equipment and log cards")
	_assert(sidebar_profile["framed_panel_count"] >= 8 and sidebar_profile["readability_score"] >= 0.74, "world sidebar console profile exposes enough framed panels for a readable playable equipment screen")
	var lore_panel_lines := sidebar_scene.get_lore_panel_lines_for_test(WorldData.get_tile_at(WorldData.create_world_state(), Vector2i(13, 10)))
	_assert(lore_panel_lines.size() == 2 and str(lore_panel_lines[0]).contains("[SYS]") and str(lore_panel_lines[0]).contains("Astraeus"), "world action panel exposes system lore signal lines")
	_assert(str(lore_panel_lines[1]).contains("[SKYE]") and str(lore_panel_lines[1]).contains("Skye"), "world action panel exposes Skye objective lines")
	var entry_tile := WorldData.get_tile_at(WorldData.create_world_state(), Vector2i(22, 6))
	var entry_context: Dictionary = sidebar_scene.get_dungeon_entry_context_for_test(entry_tile)
	var entry_readiness: Dictionary = sidebar_scene.get_dungeon_entry_readiness_for_test(entry_tile)
	var entry_card: Dictionary = sidebar_scene.get_dungeon_entry_card_for_test(entry_tile)
	_assert(entry_context["utility_belt"]["presentation"] == "anvil_to_dungeon_utility_belt" and int(entry_context["utility_belt"]["slot_count"]) == 3, "world dungeon entry context carries the Anvil utility belt into the real dungeon flow")
	_assert(not entry_readiness["ready"] and entry_readiness["missing_required"].has("10mm_wrench") and str(entry_readiness["warning"]).contains("Felix's Anvil"), "world dungeon entry blocks if the required Anvil relic is owned but not socketed")
	_assert(entry_card["presentation"] == "overworld_dungeon_loadout_card" and str(entry_card["required_label"]).contains("10mm Wrench") and str(entry_card["missing_label"]).contains("10mm Wrench"), "world action panel exposes a readable dungeon loadout card before entry")
	var kit_result: Dictionary = sidebar_scene.socket_anvil_kit_for_test("great_buffer")
	var kit_context: Dictionary = sidebar_scene.get_dungeon_entry_context_for_test(entry_tile)
	_assert(kit_result["presentation"] == "anvil_quick_socket_kit" and kit_result["socketed_tools"].has("10mm_wrench"), "Felix Workshop can quick-socket the required dungeon kit from owned analog relics")
	_assert(kit_context["loadout_check"]["ready"] and kit_context["utility_belt"]["equipped_tools"].has("10mm_wrench"), "quick-socketed Anvil kit immediately clears the real dungeon entry loadout check")
	sidebar_scene.free()
	var hatchery_profile := DragonProgression.open_hatchery_ring(DragonProgression.create_profile("fire"))
	var hatchery_state: Dictionary = DragonProgression.get_hatchery_state(hatchery_profile)
	_assert(DragonProgression.has_mission_flag(hatchery_profile, "hatchery_ring_opened") and hatchery_state["owned_dragons"].has("fire"), "opening Hatchery Ring writes real hatchery save state instead of a route-only overlay")
	var hatchery_ui: Dictionary = DragonProgression.get_hatchery_ring_ui_profile(hatchery_profile)
	_assert(hatchery_ui["presentation"] == "quantum_incubation_registry" and hatchery_ui["status_label"] == "ONLINE", "Hatchery Ring UI profile exposes real incubation registry state")
	_assert(hatchery_ui["registry_label"] == "1 dragon protocol" and hatchery_ui["visit_label"] == "1 visit logged", "Hatchery Ring UI profile reports owned dragons and visit count")
	_assert(hatchery_ui["chrome_style"]["panel_kind"] == "incubation_ring_registry" and hatchery_ui["chrome_style"]["border_color"] == Color("#c0c8ff"), "Hatchery Ring UI profile carries incubation chrome style tokens")
	var hatchery_sidebar := WorldScene.new()
	hatchery_sidebar.set_profile(hatchery_profile)
	var hatchery_sidebar_profile: Dictionary = hatchery_sidebar.get_sidebar_console_profile()
	_assert(hatchery_sidebar_profile["hatchery_status_label"] == "ONLINE" and hatchery_sidebar_profile["hatchery_registry_label"] == "1 dragon protocol", "world sidebar console exposes Hatchery Ring registry status")
	hatchery_sidebar.free()
	_assert(DragonProgression.can_learn(profile, "quakeWing"), "fire dragon can afford compatible quake wing")
	profile = DragonProgression.learn_technique(profile, "quakeWing")
	_assert(profile["known_techniques"].has("quakeWing"), "learned technique is recorded")
	_assert(DragonProgression.get_active_techniques(profile).has("quakeWing"), "new technique auto-equips when loadout has room")
	_assert(profile["data_scraps"] == 140, "learning spends data scraps")
	var fire_roster_profile := DragonProgression.switch_dragon(profile, "shadow")
	_assert(not fire_roster_profile["known_techniques"].has("quakeWing"), "dragon switch loads the new dragon's own techniques")
	fire_roster_profile = DragonProgression.switch_dragon(fire_roster_profile, "fire")
	_assert(fire_roster_profile["known_techniques"].has("quakeWing"), "switching back preserves fire dragon training")
	profile = DragonProgression.award_scraps(profile, 90)
	_assert(profile["data_scraps"] == 230, "victory rewards add data scraps")

	var trained_battle := TacticalBattle.create_battle("fire", DragonProgression.get_active_techniques(profile))
	var commands := TacticalBattle.get_battle_commands("fire", trained_battle["known_techniques"])
	_assert(_has_command(commands, "quakeWing"), "learned technique appears in battle commands")
	var search_daemon_battle := TacticalBattle.create_battle("fire", profile["known_techniques"], "search_index_daemon")
	_assert(search_daemon_battle["enemy_name"] == "Search & Index Daemon", "first route battle can start the search and index daemon")
	_assert(search_daemon_battle["enemy_intent"]["label"] == "Indexing beam", "search and index daemon has a readable opening intent")
	var search_reward := TacticalBattle.get_victory_reward("search_index_daemon")
	_assert(search_reward["flag"] == "search_index_daemon_defeated", "search and index daemon victory unlocks the next story gate")
	var magma_vfx := BattleVfxData.get_attack_vfx_profile("magma")
	_assert(magma_vfx["impact_flash"].a >= 0.22 and magma_vfx["shake_amount"] >= 9.0 and magma_vfx["residual_particles"] == "embers", "magma VFX has dramatic flash, shake, and ember residue")
	_assert(str(magma_vfx.get("strip_path", "")).contains("magma_core_bloom_strip"), "magma VFX profile uses the generated inference strip")
	var shockwave_vfx := BattleVfxData.get_attack_vfx_profile("shockwave")
	_assert(shockwave_vfx["screen_distortion"] == "radial_ripple" and shockwave_vfx["ground_crack_count"] >= 3, "shockwave VFX adds radial distortion and ground cracking")
	_assert(str(shockwave_vfx.get("strip_path", "")).contains("quake_shockwave_strip"), "shockwave VFX profile exposes its generated strip")
	var slash_vfx := BattleVfxData.get_attack_vfx_profile("slash")
	_assert(slash_vfx["burst_kind"] == "prism" and str(slash_vfx.get("strip_path", "")).contains("prism_refraction_strip"), "slash VFX profile renders as prism refraction")
	var corrupt_vfx := BattleVfxData.get_intent_vfx_profile("corrupt")
	_assert(corrupt_vfx["chromatic_split"] > 0.0 and corrupt_vfx["residual_particles"] == "void_bits", "corrupt enemy intent creates chromatic split and void-bit residue")
	_assert(corrupt_vfx["burst_kind"] == "thread" and str(corrupt_vfx.get("strip_path", "")).contains("thread_impact_strip"), "corrupt enemy intent uses generated thread-impact VFX")
	var arena_vfx := BattleVfxData.get_arena_vfx_profile("scrap_surge")
	_assert(arena_vfx["debris_count"] >= 12 and arena_vfx["palette_jolt"] == "scrap_gold", "arena rules get visible debris and palette jolts")
	_assert(FileAccess.file_exists("res://assets/vfx/generated/magma_core_bloom_strip.png"), "generated magma-core VFX strip exists")
	_assert(FileAccess.file_exists("res://assets/vfx/generated/prism_refraction_strip.png"), "generated prism-refraction VFX strip exists")
	_assert(FileAccess.file_exists("res://assets/vfx/generated/thread_impact_strip.png"), "generated thread-impact VFX strip exists")
	_assert(FileAccess.file_exists("res://assets/vfx/generated/ascii_compile_strip.png"), "generated ASCII compile VFX strip exists")
	_assert(BattleVfxData.get_generated_strip_path("ascii_compile").contains("ascii_compile_strip"), "generated ASCII strip path is exposed to dungeon VFX")
	var ascii_compile_vfx := BattleVfxData.get_dungeon_vfx_profile("ascii_compile")
	_assert(str(ascii_compile_vfx.get("strip_path", "")).contains("ascii_compile_strip") and ascii_compile_vfx["screen_distortion"] == "scanline_burst", "ASCII compile VFX profile carries generated strip and scanline distortion")
	var thread_vfx := BattleVfxData.threadfall_overlay_profile(0.86)
	_assert(thread_vfx["glyph_count"] > 70 and thread_vfx["derender_band_alpha"] > 0.2, "high Threadfall intensity upgrades overlay density and de-render bands")
	_assert(str(thread_vfx.get("strip_path", "")).contains("thread_impact_strip") and float(thread_vfx.get("strip_opacity", 0.0)) > 0.4, "high Threadfall intensity exposes generated impact-strip overlays")
	var thread_overlay := ThreadfallOverlay.new()
	thread_overlay.set_intensity(0.9)
	_assert(thread_overlay.get_active_strip_path().contains("thread_impact_strip"), "Threadfall overlay loads the generated thread-impact strip path")
	thread_overlay.free()
	var procedural_vfx := ProceduralVfxOverlay.new()
	procedural_vfx.emit_burst("shockwave", Vector2(120, 90), shockwave_vfx)
	_assert(procedural_vfx.get_active_burst_count() == 1 and procedural_vfx.get_last_burst_kind() == "shockwave", "procedural VFX overlay can queue a shockwave burst")
	procedural_vfx.emit_burst("ascii_compile", Vector2(140, 90), ascii_compile_vfx)
	_assert(procedural_vfx.get_active_burst_count() == 2 and procedural_vfx.get_last_burst_kind() == "ascii_compile", "procedural VFX overlay can queue ASCII compile bursts")
	procedural_vfx.emit_burst("wrench_sparks", Vector2(160, 90), {"impact_flash": Color("#ffd166", 0.22)})
	_assert(procedural_vfx.get_active_burst_count() == 3 and procedural_vfx.get_last_burst_kind() == "wrench_sparks", "procedural VFX overlay can queue wrench-spark bursts")
	procedural_vfx.emit_screen_effect("chromatic_glitch", 0.75, 0.4)
	_assert(procedural_vfx.get_active_screen_effect_count() == 1 and procedural_vfx.get_last_screen_effect_id() == "chromatic_glitch", "procedural VFX overlay can queue a screen-space glitch effect")
	procedural_vfx.emit_screen_effect("scanline_burst", 0.6, 0.2)
	_assert(procedural_vfx.get_active_screen_effect_count() == 2, "procedural VFX overlay can stack scanline bursts with other effects")
	procedural_vfx.advance_for_test(0.8)
	_assert(procedural_vfx.get_active_burst_count() == 0, "procedural VFX overlay expires bursts after their lifetime")
	_assert(procedural_vfx.get_active_screen_effect_count() == 0, "procedural VFX overlay expires screen effects after their lifetime")
	procedural_vfx.free()
	var reactive_backdrop := BattleBackdrop.new()
	reactive_backdrop.set_vfx_pressure("scrap_gold", 0.8, 0.5)
	_assert(reactive_backdrop.get_vfx_pressure() > 0.7 and reactive_backdrop.get_palette_jolt() == "scrap_gold", "battle backdrop can hold reactive VFX pressure")
	reactive_backdrop.advance_for_test(0.6)
	_assert(reactive_backdrop.get_vfx_pressure() == 0.0, "battle backdrop VFX pressure decays after its pulse")
	reactive_backdrop.free()
	var mirror_projection_battle := TacticalBattle.create_battle("fire", profile["known_techniques"], "mirror_admin_projection")
	_assert(mirror_projection_battle["enemy_name"] == "Mirror Admin Projection", "act two route can start the mirror admin projection battle")
	_assert(mirror_projection_battle["enemy_intent"]["label"] == "Parity scan", "mirror admin projection opens with readable parity pressure")
	var battle_scene := BattleSceneScript.new()
	_assert(str(battle_scene.get_lore_bark_for_test("mirror_admin_projection")).contains("Mirror Admin pressure"), "battle scene exposes Mirror Admin intro bark")
