	dungeon_scene.set_boss_phase_for_test(0.62)
	_assert(dungeon_scene.get_boss_core_vulnerable(), "hardware dungeon scene exposes anomaly core during recovery window")
	_assert(dungeon_scene.disable_boss_core("jam_sorting_arm"), "hardware dungeon scene can disable the active anomaly core")
